# ---- Xcode / Swift build artifacts ----
build/
DerivedData/
*.xcuserstate
*.xcuserdatad/
**/xcuserdata/
**/.swiftpm/xcode/xcuserdata/
.swiftpm/
.build/
# Xcode-managed resolved SPM cache (NOT local packages like
# High Videlity/Packages/RealityKitContent — those are tracked source)
**/project.xcworkspace/xcshareddata/swiftpm/
Package.resolved
*.xcworkspace/xcuserdata/
# Reality Composer Pro user-specific files
*.rcuserdata

# ---- Local Claude Code / IDE settings (personal preferences) ----
.claude/

# ---- Secrets (API keys etc.) — see Secrets.example.swift for template ----
**/Secrets.swift

# ---- macOS junk ----
.DS_Store

# ---- Logs / temp / OS ----
*.log
*.tmp
*.swp

# ---- Python bytecode (catch anywhere, incl. StemAnalysis sidecar) ----
__pycache__/
*.pyc

# ---- ML model weights & probe artifacts (large binaries — never commit) ----
*.pkl
*.safetensors
*.f32
StemAnalysis/mlx_checkpoints/
StemAnalysis/**/artifacts/

# ---- Editor scratch / fixtures ----
*.bak
StemAnalysis/**/tools/*.wav
